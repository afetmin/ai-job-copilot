# =========================
# AI Job Copilot Backend
# 复制为 backend/.env 后按需修改
# 变量前缀必须是 AI_JOB_COPILOT_
# =========================

# 基础信息
AI_JOB_COPILOT_APP_NAME=AI Job Copilot API
AI_JOB_COPILOT_SERVICE_NAME=ai-job-copilot-api
AI_JOB_COPILOT_ENVIRONMENT=development

# 向量检索配置
AI_JOB_COPILOT_CHROMA_PERSIST_DIRECTORY=./data/chroma_db
AI_JOB_COPILOT_CHROMA_COLLECTION_NAME=documents
AI_JOB_COPILOT_RETRIEVAL_CHUNK_SIZE=1000
AI_JOB_COPILOT_RETRIEVAL_CHUNK_OVERLAP=200
AI_JOB_COPILOT_INTERVIEW_RETRIEVAL_LIMIT=4

# Embedding Provider
# 可选: openai / dashscope
AI_JOB_COPILOT_EMBEDDING_PROVIDER=openai
AI_JOB_COPILOT_EMBEDDING_MODEL=text-embedding-3-large
AI_JOB_COPILOT_OPENAI_API_KEY=
AI_JOB_COPILOT_OPENAI_BASE_URL=https://api.openai.com/v1
AI_JOB_COPILOT_DASHSCOPE_API_KEY=

# LLM Provider（必填）
# 可选: openai_compatible / anthropic_compatible
AI_JOB_COPILOT_LLM_PROTOCOL=openai_compatible
AI_JOB_COPILOT_LLM_MODEL=gpt-4.1
AI_JOB_COPILOT_LLM_API_KEY=
AI_JOB_COPILOT_LLM_BASE_URL=https://api.openai.com/v1
AI_JOB_COPILOT_LLM_TEMPERATURE=0.2
